# Copy this file to .env and fill in your keys
# docker-compose will automatically load these

MY_GITHUB_TOKEN=your_github_personal_access_token
OPENROUTER_API_KEY=your_openrouter_api_key

# Get your free OpenRouter API key at: https://openrouter.ai/keys

# Default model for pipeline (optional, defaults to tencent/hy3-preview:free)
# Free options: meta-llama/llama-3.1-8b-instruct:free, google/gemma-2-9b-it:free
DEFAULT_MODEL=tencent/hy3-preview:free

# Model for blog generation (optional, defaults to anthropic/claude-3.5-sonnet)
# Free options: meta-llama/llama-3.1-8b-instruct:free, google/gemma-2-9b-it:free
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
